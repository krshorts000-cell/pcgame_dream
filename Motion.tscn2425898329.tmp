[sub_resource type="GDScript" id="GDScript_1tfom"]
script/source = "extends Camera3D

# --- Настройки управления ---
const MOUSE_SENS = 0.12

# --- Система выживания ---
var hunger = 100.0
var fog_timer = 100.0
const HUNGER_DECAY = 0.8
const FOG_DECAY = 1.2

# --- Настройки покачивания (Head Bob) ---
const BOB_FREQ = 2.4
const BOB_AMP = 0.06
var t_bob = 0.0

@onready var hunger_label = get_node_or_null(\"hud/Interface/hungry\")

func _ready():
	Input.mouse_mode = Input.MOUSE_MODE_CAPTURED
	# Даем кадру прогрузиться для корректной работы тумана
	await get_tree().process_frame
	apply_fog_settings()

func _input(event):
	# ВОЗВРАЩАЕМ ПОВОРОТ МЫШИ
	if event is InputEventMouseMotion:
		if get_parent() is Node3D:
			get_parent().rotate_y(deg_to_rad(-event.relative.x * MOUSE_SENS))
		
		rotate_x(deg_to_rad(-event.relative.y * MOUSE_SENS))
		rotation.x = clamp(rotation.x, deg_to_rad(-85), deg_to_rad(85))

func _process(delta):
	_process_survival(delta)
	_handle_head_bob(delta) # ВОЗВРАЩАЕМ ПОКАЧИВАНИЕ ПРИ ХОДЬБЕ
	
	# --- Логика Безумия (Тряска и сужение обзора) ---
	if DifficultyManager and DifficultyManager.current_difficulty == 2:
		var parent = get_parent()
		if \"current_madness\" in parent:
			var m = parent.current_madness
			if m > 50.0:
				var shake = (m / 100.0) * 0.04
				self.h_offset = randf_range(-shake, shake)
				self.v_offset = randf_range(-shake, shake)
			
			var base_fog = DifficultyManager.fog_distance
			self.far = lerp(base_fog, 6.0, m / 100.0)
	else:
		if DifficultyManager:
			self.far = DifficultyManager.fog_distance
		self.h_offset = 0
		self.v_offset = 0

func _process_survival(delta):
	var h_m = DifficultyManager.hunger_rate_mult if DifficultyManager else 1.0
	var f_m = DifficultyManager.madness_mult if DifficultyManager else 1.0
	
	hunger -= (HUNGER_DECAY * h_m) * delta
	fog_timer -= (FOG_DECAY * f_m) * delta
	
	if hunger_label:
		hunger_label.text = \"Голод: \" + str(int(max(0, hunger))) + \"%\"
	
	if hunger <= 0 or fog_timer <= 0:
		_go_to_menu()

func apply_fog_settings():
	if not DifficultyManager: return
	
	var env = get_world_3d().fallback_environment
	if env:
		env.fog_enabled = true
		if DifficultyManager.current_difficulty == 2:
			env.fog_density = 0.2
		else:
			env.fog_density = 0.02
			
		var scene = get_tree().current_scene.name.to_lower()
		if \"level2\" in scene:
			env.fog_light_color = Color(0.7, 0.7, 0.7)
		else:
			env.fog_light_color = Color(0, 0, 0)
			
		env.fog_depth_end = DifficultyManager.fog_distance
		self.far = DifficultyManager.fog_distance

func _handle_head_bob(delta):
	var parent = get_parent()
	if parent is CharacterBody3D and parent.is_on_floor() and parent.velocity.length() > 0.1:
		t_bob += delta * parent.velocity.length()
	else:
		t_bob = move_toward(t_bob, 0, delta * 2)
	
	transform.origin.y = sin(t_bob * BOB_FREQ) * BOB_AMP
	transform.origin.x = cos(t_bob * BOB_FREQ / 2) * BOB_AMP

func _go_to_menu():
	Input.mouse_mode = Input.MOUSE_MODE_VISIBLE
	get_tree().change_scene_to_file(\"res://menu.tscn\")
# Добавь это в самый конец Camera3D.gd
func add_food(amount):
	hunger = clamp(hunger + amount, 0, 100)
	print(\"Поел! Текущий голод: \", hunger)
"

