script/source = "extends Node3D

@export var vagon_scene: PackedScene = preload(\"res://vagon.tscn\")
@export var max_vagons: int = 5

var spawned_vagons = []

func _ready():
	print(\"Братишка, стыковочные узлы прогреты. Начинаем формирование состава!\")
	# Спавним самый первый вагон в (0,0,0)
	var first = vagon_scene.instantiate()
	add_child(first)
	spawned_vagons.append(first)
	
	# Добавляем остальные
	for i in range(max_vagons - 1):
		spawn_next_vagon()

func spawn_next_vagon():
	# 1. Берем последний вагон в очереди
	var prev_vagon = spawned_vagons.back()
	var exit_node = prev_vagon.get_node(\"end\")
	
	# 2. Создаем новый вагон
	var new_vagon = vagon_scene.instantiate()
	add_child(new_vagon)
	
	# 3. МАГИЯ СТЫКОВКИ
	# Сначала приравниваем трансформацию нового вагона к выходу старого
	new_vagon.global_transform = exit_node.global_transform
	
	# Теперь нужно сместить его так, чтобы его собственный \"start\" совпал с \"end\" старого
	# Для этого мы берем локальную позицию его \"start\" и вычитаем её
	var start_node_pos = new_vagon.get_node(\"start\").position
	new_vagon.position -= new_vagon.transform.basis * start_node_pos
	
	spawned_vagons.append(new_vagon)
	
	# Если вагонов слишком много — удаляем старый сзади
	if spawned_vagons.size() > max_vagons:
		var old = spawned_vagons.pop_front()
		old.queue_free()

func _process(_delta):
	# Простая проверка: если игрок зашел в последний вагон — спавним новый
	var player = get_node_or_null(\"../player\") # Проверь путь к игроку!
	if player:
		var last_vagon = spawned_vagons.back()
		if player.global_position.distance_to(last_vagon.global_position) < 10.0:
			spawn_next_vagon()
"

[sub_resource type="GDScript" id="GDScript_4rqvv"]
script/source = "extends CharacterBody3D

@export var speed: float = 5.0
var current_madness = 0.0
var dark_timer = 0.0 

@onready var flashlight = get_node_or_null(\"model/Flashlight\")
@onready var madness_ui = get_tree().root.find_child(\"MadnessEffect\", true, false)

func _ready():
	add_to_group(\"player\")
	# Скорость теперь берем из DifficultyManager напрямую в _physics_process
	# чтобы не множить её каждый раз при старте

func _physics_process(delta):
	# Применяем скорость в зависимости от сложности
	var current_speed = speed
	if DifficultyManager:
		current_speed = speed * DifficultyManager.player_speed_mult

	var input_dir = Vector2.ZERO
	if Input.is_key_pressed(KEY_W): input_dir.y -= 1
	if Input.is_key_pressed(KEY_S): input_dir.y += 1
	if Input.is_key_pressed(KEY_A): input_dir.x -= 1
	if Input.is_key_pressed(KEY_D): input_dir.x += 1
	
	var dir = (transform.basis * Vector3(input_dir.x, 0, input_dir.y)).normalized()
	
	if dir:
		velocity.x = dir.x * current_speed
		velocity.z = dir.z * current_speed
	else:
		velocity.x = move_toward(velocity.x, 0, current_speed)
		velocity.z = move_toward(velocity.z, 0, current_speed)
	
	if not is_on_floor(): 
		velocity.y -= 20.0 * delta
	move_and_slide()
	
	# --- ЛОГИКА БЕЗУМИЯ ---
	var light_on = false
	if is_instance_valid(flashlight): light_on = flashlight.visible
	
	if light_on:
		dark_timer = 0.0
		current_madness = move_toward(current_madness, 0.0, 10.0 * delta)
	else:
		var m_mult = DifficultyManager.madness_mult if DifficultyManager else 1.0
		dark_timer += delta * m_mult
		if dark_timer >= 60.0:
			current_madness = move_toward(current_madness, 100.0, 1.5 * m_mult * delta)
		
	# ИСПРАВЛЕННАЯ ВИДИМОСТЬ ЭФФЕКТА:
	if madness_ui:
		var diff = DifficultyManager.current_difficulty if DifficultyManager else 0
		if diff == 2: # Только на Кошмаре экран темнеет сильно
			madness_ui.modulate.a = clamp((current_madness - 15.0) / 85.0, 0, 0.9)
		else: # На норме и харде — почти незаметно
			madness_ui.modulate.a = clamp((current_madness - 60.0) / 40.0, 0, 0.3)

func _input(event):
	if event is InputEventKey and event.pressed and event.keycode == KEY_F:
		if is_instance_valid(flashlight):
			flashlight.visible = !flashlight.visible
"

