[sub_resource type="GDScript" id="GDScript_cklaw"]
script/source = "extends CharacterBody3D

@export var speed = 4.0
@export var sound_path = \"res://Final_Scream.mp3\" # Путь к звуку
@export var kill_dist = 1.5 # Расстояние поимки

var target = null

func _ready():
	# 1. Отвязываем от поезда (мировые координаты)
	top_level = true 
	
	# 2. Ищем игрока
	target = get_tree().get_first_node_in_group(\"player\")
	
	# 3. ВКЛЮЧАЕМ СТРАШНЫЙ ЗВУК СРАЗУ
	var audio = AudioStreamPlayer3D.new()
	if ResourceLoader.exists(sound_path):
		audio.stream = load(sound_path)
		audio.unit_size = 30.0 # Слышно издалека
		audio.autoplay = true
		add_child(audio)

func _physics_process(_delta):
	# 4. ДВИЖЕНИЕ БЕСКОНЕЧНО ПО Z (ИГНОР ПРЕПЯТСТВИЙ)
	# Мы просто прибавляем скорость к позиции, игнорируя стены
	global_position.z += speed * _delta

func _trigger_screamer():
	# ОТПРАВЛЯЕМ НА СЦЕНУ СКРИМЕРА
	if abs(global_position.z - target.global_position.z) < 0.5:
		get_tree().change_scene_to_file(\"res://ScreamerScene.tscn\")
"

