[sub_resource type="GDScript" id="GDScript_qlfv2"]
script/source = "extends Node3D

@export var vagon_scene: PackedScene = preload(\"res://vagon.tscn\")
@export var vagon_len: float = 14.3  # Длина между маяками

# НАСТРОЙКИ ДИСТАНЦИИ (крути в инспекторе)
@export var dist_forward: int = 50    # Сколько вагонов впереди игрока
@export var dist_backward: int = 50   # Сколько вагонов позади игрока

var spawned_vagons = {}

func _process(_delta):
	# Ищем твоего челика
	var player = get_parent().find_child(\"player\", true, false) 
	if not player:
		return

	# Считаем текущий индекс (где тусуется игрок)
	var current_idx = int(floor(player.global_position.z / -vagon_len))

	# 1. ГЕНЕРАЦИЯ (от \"сейчас - назад\" до \"сейчас + вперед\")
	for i in range(current_idx - dist_backward, current_idx + dist_forward + 1):
		if not spawned_vagons.has(i):
			var v = vagon_scene.instantiate()
			add_child(v)
			v.position.z = i * -vagon_len
			spawned_vagons[i] = v
			print(\"Приварил вагон №: \", i)

	# 2. ЖЕСТОЧАЙШАЯ ОЧИСТКА (чтобы ОЗУ не пошло по пизде)
	for k in spawned_vagons.keys():
		# Если вагон слишком далеко спереди ИЛИ слишком далеко сзади
		if k > current_idx + dist_forward + 1 or k < current_idx - dist_backward - 1:
			spawned_vagons[k].queue_free()
			spawned_vagons.erase(k)
			print(\"Отрезал лишний вагон №: \", k)
"

[sub_resource type="GDScript" id="GDScript_cu6rn"]
script/source = "extends CharacterBody3D

@export var speed: float = 5.0
var current_madness = 0.0

@onready var madness_ui = get_tree().root.find_child(\"MadnessEffect\", true, false)

func _ready():
	add_to_group(\"player\")

func _physics_process(delta):
	# --- ПРИМЕНЯЕМ СЛОЖНОСТЬ (СКОРОСТЬ) ---
	var current_speed = speed
	if DifficultyManager:
		current_speed = speed * DifficultyManager.player_speed_mult

	# WASD Движение
	var input_dir = Vector2.ZERO
	if Input.is_key_pressed(KEY_W): input_dir.y -= 1
	if Input.is_key_pressed(KEY_S): input_dir.y += 1
	if Input.is_key_pressed(KEY_A): input_dir.x -= 1
	if Input.is_key_pressed(KEY_D): input_dir.x += 1
	
	var dir = (transform.basis * Vector3(input_dir.x, 0, input_dir.y)).normalized()
	
	if dir:
		velocity.x = dir.x * current_speed
		velocity.z = dir.z * current_speed
	else:
		velocity.x = move_toward(velocity.x, 0, current_speed)
		velocity.z = move_toward(velocity.z, 0, current_speed)
	
	if not is_on_floor(): 
		velocity.y -= 20.0 * delta
		
	move_and_slide()
	
	# --- ЛОГИКА БЕЗУМИЯ (Зависит от сложности) ---
	var m_mult = 1.0
	var diff = 0
	if DifficultyManager:
		m_mult = DifficultyManager.madness_mult
		diff = DifficultyManager.current_difficulty
	
	# Базовый рост: 10 очков за 60 сек (0.1667) * множитель сложности
	# На кошмаре (x5) это будет уже 50 очков за минуту!
	current_madness = move_toward(current_madness, 100.0, 0.1667 * m_mult * delta)
		
	# Визуальный эффект (Рожи)
	if madness_ui:
		# На Кошмаре рожи начинают лезть раньше (с 30 безумия)
		var threshold = 70.0 if diff < 2 else 30.0
		var max_alpha = 1.0 if diff == 2 else 0.7 # На кошмаре рожи четче
		
		var madness_alpha = clamp((current_madness - threshold) / (100.0 - threshold), 0.0, max_alpha)
		madness_ui.modulate.a = madness_alpha

func get_madness_percent():
	return current_madness
"

