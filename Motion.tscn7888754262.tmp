[sub_resource type="GDScript" id="GDScript_8r4lo"]
script/source = "extends Node3D

@export var vagon_scene: PackedScene
@export var smiler_scene: PackedScene
@export var vagon_len: float = 14.3

var spawned_vagons = {}
var test_smiler = null # Ссылка на нашего подопытного

func _ready():
	# Ждем секунду, чтобы мир прогрузился
	await get_tree().create_timer(1.0).timeout
	spawn_test_smiler()

func spawn_test_smiler():
	var player = get_parent().find_child(\"player\", true, false)
	if player and smiler_scene:
		test_smiler = smiler_scene.instantiate()
		get_tree().current_scene.add_child(test_smiler)
		
		# Ставим его в 10 метрах позади игрока по оси Z
		test_smiler.global_position = player.global_position + Vector3(0, 1.0, 10.0)
		print(\"--- ТЕСТ: Смайлер создан! ---\")
	else:
		print(\"--- ОШИБКА: Не нашел игрока или префаб Смайлера! ---\")

func _process(_delta):
	var player = get_parent().find_child(\"player\", true, false)
	if not player: return

	# ВЫВОД КООРДИНАТ В КОНСОЛЬ
	if test_smiler:
		var dist = player.global_position.distance_to(test_smiler.global_position)
		print(\"Игрок: \", player.global_position, \" | Смайлер: \", test_smiler.global_position, \" | Дистанция: \", snapped(dist, 0.1))
	
	# Логика вагонов (чтобы не провалиться в пустоту)
	var current_idx = int(floor(player.global_position.z / -vagon_len))
	for i in range(current_idx - 2, current_idx + 5):
		if not spawned_vagons.has(i):
			var v = vagon_scene.instantiate()
			add_child(v)
			v.position.z = i * -vagon_len
			spawned_vagons[i] = v
"

