[sub_resource type="GDScript" id="GDScript_4csm4"]
script/source = "extends MeshInstance3D

# Настройки ландшафта в Инспекторе
@export_group(\"Параметры сетки\")
@export var size: int = 64          # Размер сетки (количество квадратов)
@export var mesh_step: float = 2.0  # Расстояние между точками (общий размер = size * mesh_step)

@export_group(\"Параметры шума\")
@export var height_mult: float = 12.0 # Максимальная высота холмов
@export var noise_freq: float = 0.04  # Частота (чем меньше, тем плавнее равнины)

func _ready():
	_generate_terrain()

func _generate_terrain():
	# 1. Создаем инструменты
	var st = SurfaceTool.new()
	var noise = FastNoiseLite.new()
	
	# Настройка шума (чтобы каждый раз было по-разному)
	noise.seed = randi()
	noise.frequency = noise_freq
	noise.noise_type = FastNoiseLite.TYPE_PERLIN

	# Начинаем рисовать треугольники
	st.begin(Mesh.PRIMITIVE_TRIANGLES)
	
	# 2. ГЕНЕРАЦИЯ ВЕРШИН (Точки в пространстве)
	# Проходим по X и Z, вычисляя высоту Y через шум
	for z in range(size + 1):
		for x in range(size + 1):
			var pos_x = x * mesh_step
			var pos_z = z * mesh_step
			
			# Тот самый шум Перлина для высоты
			var y = noise.get_noise_2d(pos_x, pos_z) * height_mult
			
			# Указываем UV (чтобы текстура травы легла ровно)
			var uv = Vector2(float(x) / size, float(z) / size)
			st.set_uv(uv)
			
			# Добавляем саму точку в меш
			st.add_vertex(Vector3(pos_x, y, pos_z))

	# 3. ГЕНЕРАЦИЯ ИНДЕКСОВ (Соединяем точки в треугольники)
	for z in range(size):
		for x in range(size):
			# Индексы четырех углов одного квадрата сетки
			var v1 = z * (size + 1) + x
			var v2 = v1 + 1
			var v3 = (z + 1) * (size + 1) + x
			var v4 = v3 + 1
			
			# Первый треугольник квадрата
			st.add_index(v1)
			st.add_index(v2)
			st.add_index(v3)
			
			# Второй треугольник квадрата
			st.add_index(v2)
			st.add_index(v4)
			st.add_index(v3)

	# 4. ФИНАЛИЗАЦИЯ
	st.generate_normals() # Чтобы свет и тени работали корректно
	
	# Создаем ArrayMesh и записываем его в MeshInstance3D
	var final_mesh = st.commit()
	self.mesh = final_mesh
	
	# --- ВОТ ТУТ МЫ ДОБАВЛЯЕМ КОЛЛИЗИЮ ---
	# Эта функция берет созданный меш и делает по нему невидимую стенку
	create_trimesh_collision()
	
	print(\"Уровень сгенерирован. Коллизия готова!\")
"

