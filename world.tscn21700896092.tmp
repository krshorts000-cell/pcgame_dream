script/source = "extends CharacterBody3D

# --- НАСТРОЙКИ ---
@export var walk_speed = 4.0
@export var run_speed = 7.0
@export var jump_velocity = 4.5
const ACCEL = 10.0
const FRICTION = 8.0

var current_madness = 0.0
const MAX_MADNESS = 100.0
const DARK_GROWTH_RATE = 5.0
const LIGHT_DECAY_RATE = 10.0

# --- ССЫЛКИ ---
@onready var flashlight = find_child(\"Flashlight\", true, false) as OmniLight3D
@onready var madness_ui = get_tree().root.find_child(\"MadnessEffect\", true, false)

var is_dead = false

func _ready():
	add_to_group(\"player\")

func _physics_process(delta):
	if is_dead: return

	# Гравитация
	if not is_on_floor():
		velocity += get_gravity() * delta

	# Прыжок
	if Input.is_action_just_pressed(\"ui_accept\") and is_on_floor():
		velocity.y = jump_velocity

	# WASD Движение
	var input_dir = Vector2.ZERO
	if Input.is_key_pressed(KEY_W): input_dir.y -= 1
	if Input.is_key_pressed(KEY_S): input_dir.y += 1
	if Input.is_key_pressed(KEY_A): input_dir.x -= 1
	if Input.is_key_pressed(KEY_D): input_dir.x += 1
	
	var direction = (transform.basis * Vector3(input_dir.x, 0, input_dir.y)).normalized()
	var speed = run_speed if Input.is_key_pressed(KEY_SHIFT) else walk_speed

	if direction:
		velocity.x = move_toward(velocity.x, direction.x * speed, ACCEL * delta)
		velocity.z = move_toward(velocity.z, direction.z * speed, ACCEL * delta)
	else:
		velocity.x = move_toward(velocity.x, 0, FRICTION * delta)
		velocity.z = move_toward(velocity.z, 0, FRICTION * delta)

	move_and_slide()
	_handle_madness(delta)

func _handle_madness(delta):
	var is_light_on = flashlight and flashlight.visible and flashlight.light_energy > 0.1
	if is_light_on:
		current_madness = move_toward(current_madness, 0.0, LIGHT_DECAY_RATE * delta)
	else:
		current_madness = move_toward(current_madness, MAX_MADNESS, DARK_GROWTH_RATE * delta)
	
	if madness_ui:
		var alpha = remap(current_madness, 30.0, 100.0, 0.0, 0.9)
		madness_ui.modulate.a = clamp(alpha, 0.0, 0.9)

func die():
	if is_dead: return
	is_dead = true
	if ResourceLoader.exists(\"res://ScreamerScene.tscn\"):
		get_tree().change_scene_to_file(\"res://ScreamerScene.tscn\")
	else:
		get_tree().reload_current_scene()

func get_madness_percent():
	return (current_madness / MAX_MADNESS) * 100.0
"

