script/source = "extends Camera3D

# --- Настройки ---
const MOUSE_SENS = 0.12

# --- Система выживания ---
var hunger = 100.0
var fog_timer = 100.0
const HUNGER_DECAY = 0.8
const FOG_DECAY = 1.2

# --- Настройки покачивания ---
const BOB_FREQ = 2.4
const BOB_AMP = 0.06
var t_bob = 0.0

@onready var hunger_bar = get_node_or_null(\"player/CharacterBody3D/Camera3D/hud/Interface/hungry\") 
@onready var fog_bar = get_node_or_null(\"player/CharacterBody3D/Camera3D/hud/Interface/FogLabel\")

func _ready():
	Input.mouse_mode = Input.MOUSE_MODE_CAPTURED

func _input(event):
	# Вращение камеры
	if event is InputEventMouseMotion:
		# Вращаем родителя (игрока) по горизонтали, если он есть
		if get_parent() is Node3D:
			get_parent().rotate_y(deg_to_rad(-event.relative.x * MOUSE_SENS))
		
		# Саму камеру вращаем по вертикали
		rotate_x(deg_to_rad(-event.relative.y * MOUSE_SENS))
		rotation.x = clamp(rotation.x, deg_to_rad(-85), deg_to_rad(85))

func _process(delta):
	# 1. Системы выживания
	_process_survival(delta)
	
	# 2. Эффект покачивания (теперь зависит от скорости родителя)
	_handle_head_bob(delta)

# --- ИСПРАВЛЕННЫЕ ПУТИ ---
# Теперь hunger ссылается на hungry, а fog на FogLabel
@onready var hunger_label = get_node_or_null(\"hud/Interface/hungry\") 

# ... (остальной код до _process_survival оставляешь без изменений) ...

func _process_survival(delta):
	hunger -= HUNGER_DECAY * delta
	fog_timer -= FOG_DECAY * delta
	
	# Обновляем текст на экране, превращая числа в строку (str) и отбрасывая дроби (int)
	if hunger_label: 
		hunger_label.text = \"Голод: \" + str(int(hunger)) + \"%\"
		
	
	# Проверки на смерть
	if hunger <= 0:
		print(\"Умер от голода\")
		_go_to_menu()
	
	if fog_timer <= 0:
		print(\"THE FOG IS HERE\")
# НОВАЯ ФУНКЦИЯ ДЛЯ ПЕРЕХОДА В МЕНЮ
func _go_to_menu():
	Input.mouse_mode = Input.MOUSE_MODE_VISIBLE # Возвращаем курсор
	get_tree().change_scene_to_file(\"res://menu.tscn\") # Укажи точный путь к сцене меню

func _handle_head_bob(delta):
	var parent = get_parent()
	# Проверяем, движется ли родитель (CharacterBody3D)
	if parent is CharacterBody3D and parent.is_on_floor() and parent.velocity.length() > 0.1:
		t_bob += delta * parent.velocity.length()
	else:
		t_bob = move_toward(t_bob, 0, delta * 2)
	
	# Смещаем только локальную позицию камеры
	transform.origin.y = sin(t_bob * BOB_FREQ) * BOB_AMP
	transform.origin.x = cos(t_bob * BOB_FREQ / 2) * BOB_AMP

func add_food(amount):
	hunger = clamp(hunger + amount, 0, 100)
"

[sub_resource type="GDScript" id="GDScript_aqk2v"]
script/source = "extends Area3D

@export var food_value = 10.0 # Сколько голода восстановит этот предмет

func _ready():
	# Подключаем сигнал: когда какое-то тело входит в зону Area3D
	body_entered.connect(_on_body_entered)

func _on_body_entered(body):
	# Проверяем, что вошедший объект — это игрок
	if body is CharacterBody3D:
		# Ищем камеру внутри игрока, так как шкала голода у нас в скрипте камеры
		# Путь: Игрок -> Camera3D
		var camera = body.get_node_or_null(\"Camera3D\")
		
		if camera and camera.has_method(\"add_food\"):
			# Вызываем функцию добавления еды, которую мы писали ранее
			camera.add_food(food_value)
			print(\"Подобрал батончик! +10 к еде\")
			
			# Удаляем ТОЛЬКО этот конкретный объект из игры
			queue_free()
"

