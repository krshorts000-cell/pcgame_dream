script/source = "extends Node3D

# --- 1. НАСТРОЙКИ ---
const SEGMENT_WIDTH = 11      
const SEGMENT_HEIGHT = 15     
const CELL_SIZE_X = 8.6       
const CELL_SIZE_Z = 11.0      
const START_POS = Vector3(0, 0, -5) 

const CHUNK_VISIBLE_DISTANCE = 60.0 
const PHANTOM_COUNT = 5             

# --- 2. РЕСУРСЫ ---
@onready var wall_scene = preload(\"res://wall.tscn\")
@onready var floor_scene = preload(\"res://floor.tscn\")
@onready var snack_scene = preload(\"res://Snack.tscn\")
@onready var monster_scene = preload(\"res://monster.tscn\")
@onready var door_scene = preload(\"res://door.tscn\")
@onready var npc_scene = preload(\"res://npc_mimic.tscn\")

# --- 3. ПЕРЕМЕННЫЕ ---
var last_real_z = 0.0
var last_phantom_z = 0.0
var phantom_segments = [] 
var real_segments = [] 
var hunger = 100.0
var monster_instance = null
@onready var status_label = Label.new()

# --- ОСНОВНЫЕ ЦИКЛЫ ---

func _ready():
	_setup_ui()
	_spawn_real_segment()
	
	last_phantom_z = last_real_z
	for i in range(PHANTOM_COUNT):
		_spawn_phantom_segment()
	
	var player = get_tree().get_first_node_in_group(\"player\")
	if player:
		var c_x = int(SEGMENT_WIDTH / 2) * CELL_SIZE_X
		player.global_position = START_POS + Vector3(c_x, 2.0, 5.0)
		_init_smart_monster()

func _process(delta):
	if Input.is_action_just_pressed(\"ui_cancel\"):
		get_tree().quit()

	var player = get_tree().get_first_node_in_group(\"player\")
	if not player: return

	if player.global_position.z > last_real_z - CHUNK_VISIBLE_DISTANCE:
		_replace_phantom_with_real()

	hunger -= delta * 0.4
	status_label.text = \"ГОЛОД: %d%%\" % int(hunger)
	if hunger <= 0: _game_over(\"Голодная смерть\")

# --- ФУНКЦИИ ГЕНЕРАЦИИ ---

func _spawn_phantom_segment():
	var phantom_node = Node3D.new()
	add_child(phantom_node)
	phantom_node.global_position = START_POS + Vector3(0, 0, last_phantom_z)
	
	for x in [0, SEGMENT_WIDTH - 1, int(SEGMENT_WIDTH/2)]:
		var pos = Vector3(x * CELL_SIZE_X, 0, 0)
		_add_obj(floor_scene, phantom_node, pos)
		_add_obj(floor_scene, phantom_node, pos + Vector3(0, 4.0, 0))
	
	phantom_segments.append(phantom_node)
	last_phantom_z += SEGMENT_HEIGHT * CELL_SIZE_Z

func _spawn_real_segment():
	var segment_node = Node3D.new()
	add_child(segment_node)
	segment_node.global_position = START_POS + Vector3(0, 0, last_real_z)
	real_segments.append(segment_node)
	
	var maze_data = _generate_logic()
	var npc_spawned_this_segment = false 
	
	for x in range(SEGMENT_WIDTH):
		for z in range(SEGMENT_HEIGHT):
			var pos = Vector3(x * CELL_SIZE_X, 0, z * CELL_SIZE_Z)
			
			_add_obj(floor_scene, segment_node, pos)
			_add_obj(floor_scene, segment_node, pos + Vector3(0, 4.0, 0))
			
			if maze_data[x][z] == 0:
				if randf() < 0.30:
					var d = door_scene.instantiate()
					segment_node.add_child(d)
					d.position = pos
					if x == 0: d.rotation_degrees.y = 90
					elif x == SEGMENT_WIDTH - 1: d.rotation_degrees.y = -90
				else:
					_add_obj(wall_scene, segment_node, pos + Vector3(0, 2.0, 0))
			else:
				# ЛОГИКА СПАВНА NPC
				var is_not_center = x != int(SEGMENT_WIDTH / 2)
				# Поднял шанс до 0.25 для тестов
				if not npc_spawned_this_segment and is_not_center and randf() < 0.25:
					_add_obj(npc_scene, segment_node, pos + Vector3(0, 1.0, 0))
					npc_spawned_this_segment = true
					print(\"MIMIC ЗАМЕЧЕН на Z: \", last_real_z + pos.z)
				
				elif randf() < 0.05:
					_add_obj(snack_scene, segment_node, pos + Vector3(0, 0.5, 0))
	
	last_real_z += SEGMENT_HEIGHT * CELL_SIZE_Z

func _replace_phantom_with_real():
	if phantom_segments.is_empty(): return
	var old_phantom = phantom_segments.pop_front()
	if is_instance_valid(old_phantom): old_phantom.queue_free()
	_spawn_real_segment()
	_spawn_phantom_segment()
	_manage_memory()

func _add_obj(scene, parent, pos):
	if not scene or not is_instance_valid(parent): return
	var inst = scene.instantiate()
	parent.add_child(inst)
	inst.position = pos

func _init_smart_monster():
	if monster_instance and is_instance_valid(monster_instance): return 
	monster_instance = monster_scene.instantiate()
	add_child(monster_instance)
	monster_instance.global_position = Vector3(0.0, 2.0, 15.0)
	
	var player = get_tree().get_first_node_in_group(\"player\")
	if player and monster_instance.has_method(\"set_target\"):
		monster_instance.set_target(player)

func _manage_memory():
	if real_segments.size() > 5:
		var old = real_segments.pop_front()
		if is_instance_valid(old): old.queue_free()

func _generate_logic():
	var data = []
	var cx = int(SEGMENT_WIDTH / 2)
	for x in range(SEGMENT_WIDTH):
		data.append([])
		for z in range(SEGMENT_HEIGHT):
			if x == 0 or x == SEGMENT_WIDTH - 1: data[x].append(0)
			elif x == cx: data[x].append(1)
			else: data[x].append(1 if randf() > 0.35 else 0)
	return data

func _setup_ui():
	var canvas = CanvasLayer.new()
	add_child(canvas)
	status_label.position = Vector2(20, 20)
	status_label.add_theme_color_override(\"font_color\", Color.YELLOW)
	canvas.add_child(status_label)

func _game_over(reason):
	print(\"ИГРА ОКОНЧЕНА: \", reason)
	get_tree().reload_current_scene()
"

