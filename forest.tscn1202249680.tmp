script/source = "extends Camera3D

# --- Настройки ---
const MOUSE_SENS = 0.12

# --- Система выживания ---
var hunger = 100.0
# В магазине туман обычно декоративный, но таймер оставим, если он нужен по сюжету
var fog_timer = 100.0 
const HUNGER_DECAY = 0.8
const FOG_DECAY = 1.2

# --- Настройки покачивания ---
const BOB_FREQ = 2.4
const BOB_AMP = 0.06
var t_bob = 0.0

# Пути к UI (проверь, чтобы в сцене shop структура узлов была такой же)
@onready var hunger_label = get_node_or_null(\"hud/Interface/hungry\") 

func _ready():
	Input.mouse_mode = Input.MOUSE_MODE_CAPTURED
	# Принудительное обновление текста при старте
	if hunger_label:
		hunger_label.text = \"Выносливость: 100%\"
	
	# Настраиваем визуал (дальность прорисовки и т.д.)
	await get_tree().process_frame
	_apply_shop_settings()

func _input(event):
	if event is InputEventMouseMotion:
		# Вращаем игрока (родителя)
		var parent = get_parent()
		if parent is Node3D:
			parent.rotate_y(deg_to_rad(-event.relative.x * MOUSE_SENS))
		
		# Вращаем саму камеру (вверх-вниз)
		rotate_x(deg_to_rad(-event.relative.y * MOUSE_SENS))
		rotation.x = clamp(rotation.x, deg_to_rad(-85), deg_to_rad(85))

func _process(delta):
	_process_survival(delta)
	_handle_head_bob(delta)
	
	# Эффекты безумия на камеру (тряска), если сложность \"Кошмар\"
	_apply_madness_effects()

func _process_survival(delta):
	# Берем множители из нашего глобального менеджера
	var h_mult = 1.0
	var f_mult = 1.0
	
	if DifficultyManager:
		h_mult = DifficultyManager.hunger_rate_mult
		f_mult = DifficultyManager.madness_mult 

	# Уменьшаем показатели
	hunger -= (HUNGER_DECAY * h_mult) * delta
	fog_timer -= (FOG_DECAY * f_mult) * delta
	
	# Обновление UI
	if hunger_label: 
		hunger_label.text = \"Выносливость: \" + str(int(max(0, hunger))) + \"%\"
	
	# Смерть
	if hunger <= 0 or fog_timer <= 0:
		_go_to_menu()

func _apply_madness_effects():
	# Тряска камеры только на Кошмаре при высоком безумии
	if DifficultyManager and DifficultyManager.current_difficulty == 2:
		var parent = get_parent()
		if \"current_madness\" in parent:
			var m = parent.current_madness
			if m > 50.0:
				var shake = (m / 100.0) * 0.03 # Легкая тряска
				self.h_offset = randf_range(-shake, shake)
				self.v_offset = randf_range(-shake, shake)

func _apply_shop_settings():
	# В магазине ставим стандартную видимость из менеджера
	if DifficultyManager:
		self.far = DifficultyManager.fog_distance
	
	# Если в магазине есть Environment, можно подкрутить его тут
	var env = get_world_3d().fallback_environment
	if env:
		# В магазине туман обычно слабее, чтобы видеть товары
		env.fog_enabled = true
		env.fog_density = 0.01 

func _handle_head_bob(delta):
	var parent = get_parent()
	if parent is CharacterBody3D and parent.is_on_floor() and parent.velocity.length() > 0.1:
		t_bob += delta * parent.velocity.length()
	else:
		t_bob = move_toward(t_bob, 0, delta * 2)
	
	transform.origin.y = sin(t_bob * BOB_FREQ) * BOB_AMP
	transform.origin.x = cos(t_bob * BOB_FREQ / 2) * BOB_AMP

func _go_to_menu():
	Input.mouse_mode = Input.MOUSE_MODE_VISIBLE
	get_tree().change_scene_to_file(\"res://menu.tscn\")

func add_food(amount):
	hunger = clamp(hunger + amount, 0, 100)
"

