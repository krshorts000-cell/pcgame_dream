[sub_resource type="GDScript" id="GDScript_m3mdi"]
script/source = "extends Node3D

func _ready():
	# 1. Ищем внутри Sketchfab_Scene узел с сеткой (MeshInstance3D)
	# Обычно импортированные модели имеют сложную иерархию, поэтому ищем рекурсивно
	_create_collision_for_all_meshes(self)

func _create_collision_for_all_meshes(node):
	if node is MeshInstance3D:
		# Генерируем коллизию на основе меша
		# Это создаст StaticBody3D и CollisionShape3D как дочерние узлы
		node.create_trimesh_collision()
		print(\"--- КОЛЛИЗИЯ: Создана для \", node.name, \" ---\")
	
	# Проходимся по всем дочерним узлам (рекурсия)
	for child in node.get_children():
		_create_collision_for_all_meshes(child)
"

[sub_resource type="GDScript" id="GDScript_vmuxp"]
script/source = "extends CharacterBody3D

# --- НАСТРОЙКИ ФИЗИКИ И СКОРОСТИ ---
@export var walk_speed = 1.0
@export var run_speed = 4.0
@export var gravity = 40.0
@export var view_distance = 40.0

# --- НАСТРОЙКИ ПАТРУЛЯ (КВАДРАТ) ---
@export var square_size = 30.0 # Размер стороны квадрата
var patrol_points = []
var current_point_idx = 0
var wait_timer = 0.0

enum State { PATROL, CHASE }
var current_state = State.PATROL

var target = null

func _ready():
	add_to_group(\"monster\")
	# 2. Настройка патруля по квадрату
	_setup_square_patrol()
	

	# Ищем игрока
	await get_tree().create_timer(0.5).timeout
	target = get_tree().get_first_node_in_group(\"player\")

func _physics_process(delta):
	# Гравитация, чтобы не летал
	if not is_on_floor():
		velocity.y -= gravity * delta
	else:
		velocity.y = -0.1

	match current_state:
		State.PATROL:
			_patrol_logic(delta)
			_check_vision()
		State.CHASE:
			_chase_logic()

	move_and_slide()

# --- ЛОГИКА ПАТРУЛЯ (КВАДРАТ) ---
func _setup_square_patrol():
	var pos = global_position
	# Генерируем 4 точки квадрата относительно начальной позиции
	patrol_points = [
		pos + Vector3(square_size, 0, 0),
		pos + Vector3(square_size, 0, square_size),
		pos + Vector3(0, 0, square_size),
		pos
	]

func _patrol_logic(delta):
	var target_pos = patrol_points[current_point_idx]
	var dist = global_position.distance_to(target_pos)
	
	if dist > 0.5:
		var dir = (target_pos - global_position).normalized()
		velocity.x = dir.x * walk_speed
		velocity.z = dir.z * walk_speed
	else:
		# Дошли до точки, ждем секунду и идем к следующей
		velocity.x = 0
		velocity.z = 0
		wait_timer += delta
		if wait_timer > 1.0:
			current_point_idx = (current_point_idx + 1) % patrol_points.size()
			wait_timer = 0.0

	# Если уперся в стену раньше времени — переходим к следующей точке
	if is_on_wall():
		current_point_idx = (current_point_idx + 1) % patrol_points.size()

# --- ЛОГИКА ПОГОНИ ---
func _chase_logic():
	if not target: 
		current_state = State.PATROL
		return
	
	var dir = (target.global_position - global_position).normalized()
	velocity.x = dir.x * run_speed
	velocity.z = dir.z * run_speed
	
	
	if global_position.distance_to(target.global_position) < 1.7:
		get_tree().change_scene_to_file(\"res://ScreamerScene.tscn\")

# --- ЗРЕНИЕ ---
func _check_vision():
	if not target: return
	var dist = global_position.distance_to(target.global_position)
	
	# Чует за спиной на 5 метрах, видит впереди на 25
	if dist < 5.0:
		current_state = State.CHASE
	elif dist < view_distance:
		var forward = -global_transform.basis.z 
		var to_player = (target.global_position - global_position).normalized()
		if forward.dot(to_player) > 0.3:
			current_state = State.CHASE

	# 1. Ищем внутри Sketchfab_Scene узел с сеткой (MeshInstance3D)
	# Обычно импортированные модели имеют сложную иерархию, поэтому ищем рекурсивно
	_create_collision_for_all_meshes(self)

func _create_collision_for_all_meshes(node):
	if node is MeshInstance3D:
		# Генерируем коллизию на основе меша
		# Это создаст StaticBody3D и CollisionShape3D как дочерние узлы
		node.create_trimesh_collision()
		print(\"--- КОЛЛИЗИЯ: Создана для \", node.name, \" ---\")
	
	# Проходимся по всем дочерним узлам (рекурсия)
	for child in node.get_children():
		_create_collision_for_all_meshes(child)
"

