[sub_resource type="GDScript" id="GDScript_dwbse"]
script/source = "extends CharacterBody3D

@export var walk_speed = 3.5
@export var run_speed = 8.5
@export var main_screen: String = \"res://menu.tscn\" # Укажи правильный путь к своему меню

@onready var player = get_tree().get_first_node_in_group(\"player\")
@onready var kill_zone = $KillZone
@onready var screamer_ui = $ScreamerUI

var is_killing = false

func _ready():
	# Прячем скример при спавне
	screamer_ui.hide()
	# Подключаем зону убийства
	kill_zone.body_entered.connect(_on_kill_zone_entered)

func _physics_process(delta):
	# Если монстр уже поймал игрока или игрока нет на сцене — ничего не делаем
	if is_killing or not player: 
		return
		
	var current_speed = walk_speed
	
	# Логика реакции на действия игрока
	if Input.is_key_pressed(KEY_CTRL):
		# Игрок крадется (зажат Ctrl) — монстр останавливается во тьме
		current_speed = 0.0 
	elif not player.is_on_floor() or Input.is_key_pressed(KEY_SHIFT):
		# Игрок прыгает или бежит — монстр впадает в ярость
		current_speed = run_speed
		
	# Движение к игроку
	if current_speed > 0:
		# Вычисляем направление
		var direction = global_position.direction_to(player.global_position)
		direction.y = 0 # Чтобы монстр не взлетал в воздух
		
		velocity = direction * current_speed
		move_and_slide()
		
		# Поворачиваем монстра лицом к игроку, чтобы выглядело жутко
		var look_pos = Vector3(player.global_position.x, global_position.y, player.global_position.z)
		look_at(look_pos, Vector3.UP)

func _on_kill_zone_entered(body):
	# Если в зону вошел игрок
	if body.is_in_group(\"player\") and not is_killing:
		is_killing = true
		
		# 1. Замораживаем физику монстра и игрока
		set_physics_process(false)
		body.set_physics_process(false)
		
		# 2. Показываем скример и играем звук
		screamer_ui.show()
		screamer_sound.play()
		
		# 3. Таймер на 10 секунд (код ставится на паузу на этой строке)
		await get_tree().create_timer(10.0).timeout
		
		# 4. Возвращаем мышку и выкидываем в меню
		Input.mouse_mode = Input.MOUSE_MODE_VISIBLE
		get_tree().change_scene_to_file(main_screen)
"

