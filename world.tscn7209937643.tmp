script/source = "extends CharacterBody3D

# --- Настройки скорости ---
@export var walk_speed = 4.0      # Обычная ходьба
@export var run_speed = 7.0       # Бег (Ctrl)
@export var crouch_speed = 2.0    # Красться (Shift)
@export var jump_velocity = 4.5   # Прыжок (Space)
# --- Настройки плавности ---
const ACCEL = 10.0
const FRICTION = 8.0

func _physics_process(delta: float) -> void:
	# 1. Гравитация
	if not is_on_floor():
		velocity += get_gravity() * delta

	# 2. Прыжок (Space)
	if Input.is_action_just_pressed(\"ui_select\") and is_on_floor(): # ui_select по умолчанию Space
		velocity.y = jump_velocity

	# 3. Определяем текущую скорость (Бег / Красться / Ходьба)
	var current_speed = walk_speed
	
	if Input.is_key_pressed(KEY_CTRL):
		current_speed = run_speed
	elif Input.is_key_pressed(KEY_SHIFT):
		current_speed = crouch_speed

	# 4. Обработка ввода WASD
	var input_dir := Input.get_vector(\"ui_left\", \"ui_right\", \"ui_up\", \"ui_down\")
	var direction := (transform.basis * Vector3(input_dir.x, 0, input_dir.y)).normalized()
	
	if direction:
		velocity.x = move_toward(velocity.x, direction.x * current_speed, ACCEL * delta)
		velocity.z = move_toward(velocity.z, direction.z * current_speed, ACCEL * delta)
	else:
		velocity.x = move_toward(velocity.x, 0, FRICTION * delta)
		velocity.z = move_toward(velocity.z, 0, FRICTION * delta)

	move_and_slide()
func _ready():
	# Добавляем этот узел в группу \"player\" программно
	add_to_group(\"player\")
"

