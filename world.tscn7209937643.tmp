[sub_resource type="GDScript" id="GDScript_fj7yv"]
script/source = "extends Node3D
var corridor_scene = preload(\"res://CorridorSegment.tscn\")
var snack_scene = preload(\"res://Snack.tscn\")
var last_corridor_position = Vector3.ZERO
var monster_spawned = false

func _ready():
	# Создаем первые 3 сегмента при старте
	for i in range(3):
		_spawn_corridor()

func _spawn_corridor():
	var instance = corridor_scene.instantiate()
	add_child(instance)
	
	# Ставим новый сегмент в точку выхода предыдущего
	instance.global_position = last_corridor_position
	
	# Обновляем точку для следующего сегмента
	# Ищем маркер выхода внутри созданного сегмента
	var exit_point = instance.get_node(\"ExitPoint\")
	last_corridor_position = exit_point.global_position
	
	# Спавним еду в этом сегменте
	_spawn_snacks_in_segment(instance)
	
	# Соединяем триггер, чтобы он вызывал новый спавн
	var trigger = instance.get_node(\"SpawnTrigger\")
	trigger.body_entered.connect(_on_player_entered_trigger.bind(instance))
	
func _spawn_snacks_in_segment(segment):
	# Ищем все точки спавна еды в сегменте
	for point in segment.get_children():
		if point.name.begins_with(\"SnackPoint\"):
			# Шанс 30%, что в этой точке появится еда
			if randf() < 0.3:
				var snack = snack_scene.instantiate()
				add_child(snack)
				snack.global_position = point.global_position

func _on_player_entered_trigger(body, segment):
	if body is CharacterBody3D:
		# Когда игрок входит в триггер, спавним следующий кусок
		_spawn_corridor()
		# Отключаем триггер, чтобы он не сработал дважды
		var trigger = segment.get_node(\"SpawnTrigger\")
		trigger.set_deferred(\"monitoring\", false)
func _input(event):
	# Проверяем, нажата ли клавиша Escape
	if event.is_action_pressed(\"ui_cancel\"): 
		# ui_cancel в Godot по умолчанию привязан к клавише Esc
		get_tree().quit()
	
"

